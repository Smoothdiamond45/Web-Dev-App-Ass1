{{> menu}}
<section class="page" id="page-about">
  <div class="about-layout">

    <!-- Left Column -->
    <div class="about-left">
      <p class="section-eyebrow">The Photographer</p>
      <h2 class="about-name">Your<br>Name Here</h2>
      <p class="about-role">Photographer · Dublin, Ireland</p>
      <div class="divider"></div>
      <p class="about-bio">
        I'm a self-taught photographer based in Dublin with a passion for landscape
        and street photography. I started shooting in 2020 and haven't put the camera
        down since. This app is a living archive of my favourite shots and the gear
        I use to take them.
      </p>

      <ul class="contact-list">
        <li><span>Email</span><span>hello@yoursite.com</span></li>
        <li><span>Phone</span><span>+353 87 000 0000</span></li>
        <li><span>Based</span><span>Dublin, Ireland</span></li>
        <li><span>Web</span><span>www.yoursite.com</span></li>
      </ul>

      <!-- Gear list (could be its own JSON-powered view for extra marks!) -->
      <p class="gear-subtitle">My Kit</p>
      <ul class="gear-list">
        <li><span>Sony A7 III</span><span>Camera Body</span></li>
        <li><span>Sony 24–70mm f/2.8 GM</span><span>Zoom Lens</span></li>
        <li><span>Sony 85mm f/1.4 GM</span><span>Portrait Lens</span></li>
        <li><span>Manfrotto 055</span><span>Tripod</span></li>
        <li><span>Moment ND Filter Set</span><span>Filters</span></li>
      </ul>
    </div>

    <!-- Right Column -->
    <div class="about-right">
      <!-- Map image — replace with your actual map screenshot -->
      <div class="map-placeholder">
        [ Map image goes here — screenshot from Google Maps ]
      </div>

      <!-- App stats from JSON -->
      <p class="section-eyebrow" style="margin-bottom:1rem">App Statistics</p>
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-num">240</div>
          <div class="stat-label">Photos</div>
        </div>
        <div class="stat-box">
          <div class="stat-num">5</div>
          <div class="stat-label">Collections</div>
        </div>
        <div class="stat-box">
          <div class="stat-num">v1.0</div>
          <div class="stat-label">Version</div>
        </div>
      </div>

      <p style="font-size:0.78rem; color: var(--muted); line-height:1.8;">
        App built as part of Web App Development module.<br>
        All photographs © Your Name, all rights reserved.
      </p>
    </div>

  </div>
</section>