{{> menu}}
<section class="page" id="page-details">
  <div class="details-header">
    <div>
      <p class="section-eyebrow">Collection</p>
      <h2 class="section-title">Landscape</h2>
    </div>
    <button class="back-btn" onclick="showPage('dashboard')">Back to Dashboard</button>
  </div>

  <div class="photo-grid">

    <div class="photo-card">
      <div class="photo-img">🏔</div>
      <!-- Replace the div above with: <img src="photo.image" style="width:100%;height:100%;object-fit:cover" /> -->
      <div class="photo-info">
        <h3 class="photo-title">Golden Hour at Howth</h3>
        <p class="photo-location">📍 Howth, Dublin, Ireland</p>
        <div class="photo-meta">
          <span class="meta-tag">f/8</span>
          <span class="meta-tag">1/250s</span>
          <span class="meta-tag">ISO 100</span>
          <span class="meta-tag">Sony A7III</span>
        </div>
      </div>
    </div>

    <div class="photo-card">
      <div class="photo-img">🌊</div>
      <div class="photo-info">
        <h3 class="photo-title">Atlantic Cliffs</h3>
        <p class="photo-location">📍 Cliffs of Moher, Clare</p>
        <div class="photo-meta">
          <span class="meta-tag">f/11</span>
          <span class="meta-tag">1/500s</span>
          <span class="meta-tag">ISO 200</span>
          <span class="meta-tag">16mm</span>
        </div>
      </div>
    </div>

    <div class="photo-card">
      <div class="photo-img">🌄</div>
      <div class="photo-info">
        <h3 class="photo-title">Wicklow Dawn</h3>
        <p class="photo-location">📍 Wicklow Mountains</p>
        <div class="photo-meta">
          <span class="meta-tag">f/5.6</span>
          <span class="meta-tag">1/80s</span>
          <span class="meta-tag">ISO 400</span>
          <span class="meta-tag">24mm</span>
        </div>
      </div>
    </div>

  </div>
</section>